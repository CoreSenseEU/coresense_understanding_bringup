
@prefix sc: <https://coresense.eu/ont/scenarios#>.
@prefix ds: <https://coresense.eu/ont/decision_system#>.
@prefix cso: <https://github.com/CoreSenseEU/CoreSense/blob/main/models/ontology/coresense_ontologies/CSO/cso.sysml#>.
@prefix csu: <https://github.com/CoreSenseEU/coresense_understanding_bringup/blob/main/preload/understanding.ttl#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.

sc:given_cues a cso:Modelet;
  csu:hasFormalism ds:cueArrayMsg;
  csu:hasRepresentationClass ds:cue_array.

sc:given_alternatives a cso:Modelet;
  csu:hasFormalism ds:alternativeArrayMsg;
  csu:hasRepresentationClass ds:choice_set;
  csu:hasRepresentationClass ds:alternative_array.
